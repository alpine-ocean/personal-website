---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths() {
    const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
    const postCount = posts.length;
    return posts.map((post, index) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: index + 1 !== postCount ? posts[index + 1] : null,
            nextPost: index !== 0 ? posts[index - 1] : null
        }
    }));
}

type Props = {
    post: CollectionEntry<'blog'>;
    prevPost: CollectionEntry<'blog'> | null;
    nextPost: CollectionEntry<'blog'> | null;
};

const { post, prevPost, nextPost } = Astro.props;
const { title, publishDate, updatedDate, excerpt, seo } = post.data;
const { Content } = await render(post);

function shortDate(date: Date) {
    return date.toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? excerpt} pageType="article">
    <div class="max-w-xl">

        <header class="mb-12 border-b border-main pb-6">
            <h1 class="font-serif text-2xl font-medium leading-snug mb-4 sm:text-3xl">
                {title}
            </h1>
            <p class="font-mono text-xs text-muted">
                {shortDate(publishDate)}
                {updatedDate && <span> · Updated {shortDate(updatedDate)}</span>}
            </p>
        </header>

        <div class="post-body">
            <Content />
        </div>

        {(prevPost || nextPost) && (
            <nav class="mt-16 pt-8 border-t border-main" aria-label="Post navigation">
                <p class="font-mono text-xs tracking-widest uppercase text-muted mb-6">More</p>
                <div class="flex flex-col gap-4">
                    {nextPost && (
                        <a href={`/blog/${nextPost.id}/`} class="group flex items-baseline justify-between gap-8">
                            <span class="font-serif text-base group-hover:text-accent transition-colors">
                                {nextPost.data.title}
                            </span>
                            <span class="font-mono text-xs text-muted shrink-0">
                                {shortDate(nextPost.data.publishDate)}
                            </span>
                        </a>
                    )}
                    {prevPost && (
                        <a href={`/blog/${prevPost.id}/`} class="group flex items-baseline justify-between gap-8">
                            <span class="font-serif text-base group-hover:text-accent transition-colors">
                                {prevPost.data.title}
                            </span>
                            <span class="font-mono text-xs text-muted shrink-0">
                                {shortDate(prevPost.data.publishDate)}
                            </span>
                        </a>
                    )}
                </div>
            </nav>
        )}

    </div>
</BaseLayout>

<style>
    .post-body {
        font-family: var(--font-serif);
        font-size: 1.0625rem;
        line-height: 1.8;
        color: var(--text-main);
    }
    .post-body :global(p + p) {
        margin-top: 1.5rem;
    }
    .post-body :global(h2) {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 500;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
    }
    .post-body :global(h3) {
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 500;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
    }
    .post-body :global(a) {
        text-decoration: underline;
        text-decoration-style: dashed;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
    }
    .post-body :global(a:hover) {
        color: var(--accent);
        text-decoration-style: solid;
    }
    .post-body :global(ul),
    .post-body :global(ol) {
        padding-left: 1.25rem;
        margin: 1.25rem 0;
    }
    .post-body :global(li + li) {
        margin-top: 0.4rem;
    }
    .post-body :global(blockquote) {
        font-style: italic;
        font-size: 1.2em;
        line-height: 1.6;
        margin: 2rem 0;
        padding-left: 1.25rem;
        border-left: 2px solid var(--border-main);
    }
    .post-body :global(strong) {
        font-weight: 600;
    }
    .post-body :global(code) {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--bg-muted);
        padding: 0.1em 0.3em;
        border-radius: 2px;
    }
    .post-body :global(hr) {
        border: none;
        border-top: 1px solid var(--border-main);
        margin: 2.5rem 0;
    }
    .post-body :global(img) {
        width: 100%;
        margin: 2rem 0;
    }
</style>
